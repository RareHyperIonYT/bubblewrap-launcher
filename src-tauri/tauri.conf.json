{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bubblewrap-Launcher",
  "version": "0.1.0",
  "identifier": "bubblewrap-launcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Bubblewrap",
        "width": 1380,
        "height": 820,
        "minWidth": 960,
        "minHeight": 600,
        "decorations": false,
        "resizable": true,
        "center": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"],
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/*", "/home/**", "/run/media/**", "$HOME/.local/share/bubblewrap-launcher/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  }
}
