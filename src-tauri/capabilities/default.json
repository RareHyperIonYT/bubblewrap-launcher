{
  "identifier": "default",
  "description": "Default capabilities for Bubblewrap Game Launcher",
  "windows": ["main"],
  "permissions": [
    "core:default",

    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:window:allow-start-dragging",

    "dialog:default",
    "dialog:allow-open",
    "shell:allow-open",
    "fs:default"
  ]
}
